<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZTAS"
        tools:replace="android:allowBackup,android:icon,android:label,android:roundIcon,android:theme">

        <!-- FCM Service -->
        <service
            android:name=".MfaMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- MFA Action Receiver -->
        <receiver
            android:name=".MfaActionReceiver"
            android:exported="false" />

        <activity
            android:name="com.ztas.app.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.ztas.app.OtpInputPage" android:exported="false" android:windowSoftInputMode="adjustResize" />
        <activity android:name="com.ztas.app.MainActivity" android:exported="false" />
        <activity android:name="com.ztas.app.NotificationPage" android:exported="false" />
        <activity android:name="com.ztas.app.RegistrationPage" android:exported="false" android:windowSoftInputMode="adjustResize" />
        <activity android:name="com.ztas.app.LoginActivity" android:exported="false" android:windowSoftInputMode="adjustResize" />
        <activity android:name="com.ztas.app.PasskeyActivity" android:exported="false" />
        <activity android:name="com.ztas.app.HomeActivity" android:exported="false" />
        <activity android:name="com.ztas.app.ProfileActivity" android:exported="false" />
        <activity android:name="com.ztas.app.MFAActivity" android:exported="false" />
        <activity android:name="com.ztas.app.SettingsActivity" android:exported="false" />

    </application>

</manifest>