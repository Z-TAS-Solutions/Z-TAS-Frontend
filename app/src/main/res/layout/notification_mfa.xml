<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0D1B2A"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Lock Icon -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/lock_icon"
        android:contentDescription="Security Icon" />

    <!-- Text Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MFA APPROVAL REQUIRED"
            android:textColor="#00D1FF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New login attempt detected. Tap to review."
            android:textColor="#8B9CB7"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/notif_device"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Windows PC • Colombo"
            android:textColor="#5A6B7D"
            android:textSize="10sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</LinearLayout>
