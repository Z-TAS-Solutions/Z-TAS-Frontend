<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0a0e27">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP HEADER WITH ICON AND TITLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Z-TAS SECURITY"
                android:textSize="14sp"
                android:textColor="#00ccff"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/settings_icon"
                android:contentDescription="Security Icon"
                app:tint="#00ccff" />

        </LinearLayout>

        <!-- CENTERED USER PROFILE INFO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="48dp">

            <!-- Profile Picture -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/circular_shapepfp"
                android:padding="2dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/profilePic"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circular_shapepfp"
                    android:clipToOutline="true"
                    android:contentDescription="@string/profile_picture"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_picture2" />
            </FrameLayout>

            <!-- User Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/username"
                android:text="Adam James"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <!-- User Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/useremail"
                android:text="adam201@gmail.com"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:gravity="center" />

            <!-- Status Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:padding="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#00ff00"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT ACTIVE"
                    android:textSize="11sp"
                    android:textColor="#00ff00"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- DIVIDER LINE -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1a3a3a"
            android:layout_marginBottom="32dp" />


        <!-- ACCOUNT SETTINGS SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT SETTINGS"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#00ccff"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp" />

        <!-- Change Password Card -->
        <LinearLayout
            android:id="@+id/changePasswordCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/lock_icon"
                android:contentDescription="Lock Icon"
                app:tint="#00ccff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Password"
                    android:textSize="15sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Update your security"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/right_arrow"
                android:contentDescription="Arrow Right"
                app:tint="#00ccff" />

        </LinearLayout>

        <!-- Active Sessions Card -->
        <LinearLayout
            android:id="@+id/activeSessionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/devices_icon"
                android:contentDescription="Devices Icon"
                app:tint="#00ccff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Sessions"
                    android:textSize="15sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/activeDevicesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 devices connected"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/right_arrow"
                android:contentDescription="Arrow Right"
                app:tint="#00ccff" />

        </LinearLayout>

        <!-- Sign Out Card -->
        <LinearLayout
            android:id="@+id/signOutCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/signout_icon"
                android:contentDescription="Sign Out Icon"
                app:tint="#00ccff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Out"
                    android:textSize="15sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exit your account"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/right_arrow"
                android:contentDescription="Arrow Right"
                app:tint="#00ccff" />

        </LinearLayout>

        <!-- Delete Account Card -->
        <LinearLayout
            android:id="@+id/deleteAccountCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="32dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/delete_icon"
                android:contentDescription="Delete Icon"
                app:tint="#ff6b6b" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delete Account"
                    android:textSize="15sp"
                    android:textColor="#ff6b6b"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permanently delete"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/right_arrow"
                android:contentDescription="Arrow Right"
                app:tint="#ff6b6b" />

        </LinearLayout>

        <!-- SYSTEM STATUS SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM STATUS"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#00ccff"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp" />

        <!-- System Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Biometric Engine:"
                    android:textSize="13sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/biometricStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ONLINE"
                    android:textSize="13sp"
                    android:textColor="#00ff00"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last Sync:"
                    android:textSize="13sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lastSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3h ago"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Security Level:"
                    android:textSize="13sp"
                    android:textColor="#ffffff"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/securityLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIGH"
                    android:textSize="13sp"
                    android:textColor="#00ff00"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>


