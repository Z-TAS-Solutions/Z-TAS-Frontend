<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0a0e27">

    <!-- Success Icon -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/checkmark_icon"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:contentDescription="Success Icon"
        app:tint="#00ff00" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email Sent!"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="A password reset email has been sent to your registered email address. Check your inbox and follow the instructions to reset your password."
        android:textSize="14sp"
        android:textColor="#888888"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp" />

    <!-- OK Button -->
    <Button
        android:id="@+id/ok_dialogbutton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="OK"
        android:textColor="#0a0e27"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:backgroundTint="@null"
        android:background="@drawable/primary_dialogbutton" />

</LinearLayout>