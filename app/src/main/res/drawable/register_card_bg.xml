<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- OUTER SOFT GLOW -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#1400C4FF"/>
        </shape>
    </item>

    <!-- OUTER BORDER -->
    <item android:inset="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp"/>
            <stroke
                android:width="1.2dp"
                android:color="#5500C4FF"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>

    <!-- INNER GLASS PANEL -->
    <item android:inset="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp"/>
            <solid android:color="#22000000"/>
        </shape>
    </item>

    <!-- INNER BORDER -->
    <item android:inset="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp"/>
            <stroke
                android:width="1dp"
                android:color="#3300C4FF"/>
        </shape>
    </item>
    <item android:inset="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp"/>
            <solid android:color="#E6050A18"/>
        </shape>
    </item>

</layer-list>