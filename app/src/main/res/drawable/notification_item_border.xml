<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1B2A" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- Border -->
    <item android:top="0.5dp" android:bottom="0.5dp" android:left="0.5dp" android:right="0.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D1B2A" />
            <corners android:radius="9.5dp" />
            <stroke
                android:width="0.5dp"
                android:color="#1E3A5F" />
        </shape>
    </item>
</layer-list>